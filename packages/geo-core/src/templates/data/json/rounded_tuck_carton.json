{
  "key": "folding_carton.rounded_tuck_carton",
  "label": "Roll End Tuck Front Mailer Box",
  "package_kind": "folding_carton",
  "numeric_params": [
    {
      "key": "target_width",
      "label": "Box Width",
      "default_value": 360,
      "min_value": 1
    },
    {
      "key": "target_depth",
      "label": "Box Depth",
      "default_value": 300,
      "min_value": 1
    },
    {
      "key": "target_height",
      "label": "Box Height",
      "default_value": 100,
      "min_value": 1
    },
    {
      "key": "wall_angle_rad",
      "label": "Wall Angle",
      "default_value": 1.5707963267948966,
      "min_value": -3.141592653589793,
      "max_value": 3.141592653589793
    },
    {
      "key": "lid_angle_rad",
      "label": "Lid Angle",
      "default_value": 1.7278759594743864,
      "min_value": -3.141592653589793,
      "max_value": 3.141592653589793
    },
    {
      "key": "tuck_angle_rad",
      "label": "Tuck Angle",
      "default_value": 1.5707963267948966,
      "min_value": -3.141592653589793,
      "max_value": 3.141592653589793
    },
    {
      "key": "roll_fold_angle_rad",
      "label": "Roll Fold Angle",
      "default_value": 3.141592653589793,
      "min_value": -3.141592653589793,
      "max_value": 3.141592653589793
    }
  ],
  "variables": [
    { "name": "w", "expr": "target_width" },
    { "name": "d", "expr": "target_depth" },
    { "name": "h", "expr": "target_height" },
    { "name": "tuck_len", "expr": "h * 0.8" },
    { "name": "dust_outset", "expr": "h * 1.2" },
    { "name": "dust_curve_inset", "expr": "h * 0.8" },
    { "name": "side_dust_bevel", "expr": "h * 0.2" },

    { "name": "x0", "expr": "-h * 2" },
    { "name": "x1", "expr": "-h" },
    { "name": "x2", "expr": "w - w" },
    { "name": "x3", "expr": "w" },
    { "name": "x4", "expr": "w + h" },
    { "name": "x5", "expr": "w + h * 2" },
    { "name": "x_dust_left", "expr": "-dust_outset" },
    { "name": "x_dust_right", "expr": "w + dust_outset" },

    { "name": "y0", "expr": "d - d" },
    { "name": "y1", "expr": "tuck_len" },
    { "name": "y2", "expr": "tuck_len + h" },
    { "name": "y3", "expr": "tuck_len + h + d" },
    { "name": "y4", "expr": "tuck_len + h + d + h" },
    { "name": "y5", "expr": "tuck_len + h + d + h + d" },
    { "name": "y6", "expr": "tuck_len + h + d + h + d + tuck_len" },

    { "name": "y_left_notch1_bottom", "expr": "y2 + h * 0.6" },
    { "name": "y_left_notch1_top", "expr": "y2 + h" },
    { "name": "y_left_notch2_bottom", "expr": "y2 + d * 0.2" },
    { "name": "y_left_notch2_top", "expr": "y2 + d * 0.2 + h * 0.4" },
    { "name": "y_left_notch3_bottom", "expr": "y2 + d * 0.6" },
    { "name": "y_left_notch3_top", "expr": "y2 + d * 0.6 + h * 0.4" },

    { "name": "y_right_notch1_bottom", "expr": "y2 + d * 0.2" },
    { "name": "y_right_notch1_top", "expr": "y2 + d * 0.2 + h * 0.4" },
    { "name": "y_right_notch2_bottom", "expr": "y2 + d * 0.6" },
    { "name": "y_right_notch2_top", "expr": "y2 + d * 0.6 + h * 0.4" },
    { "name": "y_right_notch3_bottom", "expr": "y2 + d * 0.6666666667" },
    { "name": "y_right_notch3_top", "expr": "y2 + d * 0.6666666667 + h * 0.4" },

    { "name": "y_dust_top_start", "expr": "y4 + dust_curve_inset" },
    { "name": "y_dust_top_end", "expr": "y5 - dust_curve_inset" }
  ],
  "panels": [
    {
      "name": "front_wall",
      "boundary": [
        { "from": { "x": "x2", "y": "y2" }, "to": { "x": "x2", "y": "y1" } },
        { "from": { "x": "x2", "y": "y1" }, "to": { "x": "x3", "y": "y1" } },
        { "from": { "x": "x3", "y": "y1" }, "to": { "x": "x3", "y": "y2" } },
        { "from": { "x": "x3", "y": "y2" }, "to": { "x": "x2", "y": "y2" } }
      ]
    },
    {
      "name": "bottom",
      "boundary": [
        { "from": { "x": "x2", "y": "y3" }, "to": { "x": "x2", "y": "y2" } },
        { "from": { "x": "x2", "y": "y2" }, "to": { "x": "x3", "y": "y2" } },
        { "from": { "x": "x3", "y": "y2" }, "to": { "x": "x3", "y": "y3" } },
        { "from": { "x": "x3", "y": "y3" }, "to": { "x": "x2", "y": "y3" } }
      ]
    },
    {
      "name": "back_wall",
      "boundary": [
        { "from": { "x": "x2", "y": "y4" }, "to": { "x": "x2", "y": "y3" } },
        { "from": { "x": "x2", "y": "y3" }, "to": { "x": "x3", "y": "y3" } },
        { "from": { "x": "x3", "y": "y3" }, "to": { "x": "x3", "y": "y4" } },
        { "from": { "x": "x3", "y": "y4" }, "to": { "x": "x2", "y": "y4" } }
      ]
    },
    {
      "name": "top_lid",
      "boundary": [
        { "from": { "x": "x2", "y": "y5" }, "to": { "x": "x2", "y": "y4" } },
        { "from": { "x": "x2", "y": "y4" }, "to": { "x": "x3", "y": "y4" } },
        { "from": { "x": "x3", "y": "y4" }, "to": { "x": "x3", "y": "y5" } },
        { "from": { "x": "x3", "y": "y5" }, "to": { "x": "x2", "y": "y5" } }
      ]
    },
    {
      "name": "top_lid_tuck",
      "accepts_content": false,
      "boundary": [
        { "from": { "x": "x2", "y": "y5" }, "to": { "x": "x3", "y": "y5" } },
        { "from": { "x": "x3", "y": "y5" }, "to": { "x": "x3", "y": "y5 + h * 0.4" } },
        {
          "kind": "bezier",
          "p0": { "x": "x3", "y": "y5 + h * 0.4" },
          "p1": { "x": "x3", "y": "y5 + h * 0.7" },
          "p2": { "x": "x3 - h * 0.2", "y": "y6" },
          "p3": { "x": "x3 - h * 0.4", "y": "y6" }
        },
        { "from": { "x": "x3 - h * 0.4", "y": "y6" }, "to": { "x": "x2 + h * 0.4", "y": "y6" } },
        {
          "kind": "bezier",
          "p0": { "x": "x2 + h * 0.4", "y": "y6" },
          "p1": { "x": "x2 + h * 0.2", "y": "y6" },
          "p2": { "x": "x2", "y": "y5 + h * 0.7" },
          "p3": { "x": "x2", "y": "y5 + h * 0.4" }
        },
        { "from": { "x": "x2", "y": "y5 + h * 0.4" }, "to": { "x": "x2", "y": "y5" } }
      ]
    },
    {
      "name": "dust_flap_left",
      "accepts_content": false,
      "boundary": [
        { "from": { "x": "x2", "y": "y4" }, "to": { "x": "x2", "y": "y5" } },
        {
          "kind": "bezier",
          "p0": { "x": "x2", "y": "y5" },
          "p1": { "x": "x_dust_left + h * 0.7", "y": "y5" },
          "p2": { "x": "x_dust_left", "y": "y5 - h * 0.4" },
          "p3": { "x": "x_dust_left", "y": "y_dust_top_end" }
        },
        { "from": { "x": "x_dust_left", "y": "y_dust_top_end" }, "to": { "x": "x_dust_left", "y": "y_dust_top_start" } },
        {
          "kind": "bezier",
          "p0": { "x": "x_dust_left", "y": "y_dust_top_start" },
          "p1": { "x": "x_dust_left", "y": "y4 + h * 0.4" },
          "p2": { "x": "x_dust_left + h * 0.7", "y": "y4" },
          "p3": { "x": "x2", "y": "y4" }
        }
      ]
    },
    {
      "name": "dust_flap_right",
      "accepts_content": false,
      "boundary": [
        { "from": { "x": "x3", "y": "y5" }, "to": { "x": "x3", "y": "y4" } },
        {
          "kind": "bezier",
          "p0": { "x": "x3", "y": "y4" },
          "p1": { "x": "x_dust_right - h * 0.7", "y": "y4" },
          "p2": { "x": "x_dust_right", "y": "y4 + h * 0.4" },
          "p3": { "x": "x_dust_right", "y": "y_dust_top_start" }
        },
        { "from": { "x": "x_dust_right", "y": "y_dust_top_start" }, "to": { "x": "x_dust_right", "y": "y_dust_top_end" } },
        {
          "kind": "bezier",
          "p0": { "x": "x_dust_right", "y": "y_dust_top_end" },
          "p1": { "x": "x_dust_right", "y": "y5 - h * 0.4" },
          "p2": { "x": "x_dust_right - h * 0.7", "y": "y5" },
          "p3": { "x": "x3", "y": "y5" }
        }
      ]
    },
    {
      "name": "side_outer_left",
      "boundary": [
        { "from": { "x": "x1", "y": "y3" }, "to": { "x": "x1", "y": "y2" } },
        { "from": { "x": "x1", "y": "y2" }, "to": { "x": "x2", "y": "y2" } },
        { "from": { "x": "x2", "y": "y2" }, "to": { "x": "x2", "y": "y3" } },
        { "from": { "x": "x2", "y": "y3" }, "to": { "x": "x1", "y": "y3" } }
      ]
    },
    {
      "name": "side_inner_left",
      "accepts_content": false,
      "boundary": [
        { "from": { "x": "x1", "y": "y2" }, "to": { "x": "x1", "y": "y3" } },
        { "from": { "x": "x1", "y": "y3" }, "to": { "x": "x0", "y": "y3" } },
        { "from": { "x": "x0", "y": "y3" }, "to": { "x": "x0", "y": "y_left_notch3_top" } },
        { "from": { "x": "x0", "y": "y_left_notch3_top" }, "to": { "x": "x0 - h * 0.2", "y": "y_left_notch3_top" } },
        { "from": { "x": "x0 - h * 0.2", "y": "y_left_notch3_top" }, "to": { "x": "x0 - h * 0.2", "y": "y_left_notch3_bottom" } },
        { "from": { "x": "x0 - h * 0.2", "y": "y_left_notch3_bottom" }, "to": { "x": "x0", "y": "y_left_notch3_bottom" } },
        { "from": { "x": "x0", "y": "y_left_notch3_bottom" }, "to": { "x": "x0", "y": "y_left_notch2_top" } },
        { "from": { "x": "x0", "y": "y_left_notch2_top" }, "to": { "x": "x0 - h * 0.2", "y": "y_left_notch2_top" } },
        { "from": { "x": "x0 - h * 0.2", "y": "y_left_notch2_top" }, "to": { "x": "x0 - h * 0.2", "y": "y_left_notch2_bottom" } },
        { "from": { "x": "x0 - h * 0.2", "y": "y_left_notch2_bottom" }, "to": { "x": "x0", "y": "y_left_notch2_bottom" } },
        { "from": { "x": "x0", "y": "y_left_notch2_bottom" }, "to": { "x": "x0", "y": "y2" } },
        { "from": { "x": "x0", "y": "y2" }, "to": { "x": "x1", "y": "y2" } }
      ]
    },
    {
      "name": "side_dust_top_left",
      "accepts_content": false,
      "boundary": [
        { "from": { "x": "x2", "y": "y2" }, "to": { "x": "x1", "y": "y2" } },
        { "from": { "x": "x1", "y": "y2" }, "to": { "x": "x1", "y": "y1" } },
        { "from": { "x": "x1", "y": "y1" }, "to": { "x": "x2", "y": "y1" } },
        { "from": { "x": "x2", "y": "y1" }, "to": { "x": "x2", "y": "y2" } }
      ]
    },
    {
      "name": "side_dust_bottom_left",
      "accepts_content": false,
      "boundary": [
        { "from": { "x": "x1", "y": "y3" }, "to": { "x": "x2", "y": "y3" } },
        { "from": { "x": "x2", "y": "y3" }, "to": { "x": "x2", "y": "y4" } },
        { "from": { "x": "x2", "y": "y4" }, "to": { "x": "x1", "y": "y4" } },
        { "from": { "x": "x1", "y": "y4" }, "to": { "x": "x1", "y": "y3" } }
      ]
    },
    {
      "name": "side_outer_right",
      "boundary": [
        { "from": { "x": "x3", "y": "y2" }, "to": { "x": "x4", "y": "y2" } },
        { "from": { "x": "x4", "y": "y2" }, "to": { "x": "x4", "y": "y3" } },
        { "from": { "x": "x4", "y": "y3" }, "to": { "x": "x3", "y": "y3" } },
        { "from": { "x": "x3", "y": "y3" }, "to": { "x": "x3", "y": "y2" } }
      ]
    },
    {
      "name": "side_inner_right",
      "accepts_content": false,
      "boundary": [
        { "from": { "x": "x4", "y": "y3" }, "to": { "x": "x4", "y": "y2" } },
        { "from": { "x": "x4", "y": "y2" }, "to": { "x": "x5", "y": "y2" } },
        { "from": { "x": "x5", "y": "y2" }, "to": { "x": "x5", "y": "y_right_notch1_bottom" } },
        { "from": { "x": "x5", "y": "y_right_notch1_bottom" }, "to": { "x": "x5 + h * 0.2", "y": "y_right_notch1_bottom" } },
        { "from": { "x": "x5 + h * 0.2", "y": "y_right_notch1_bottom" }, "to": { "x": "x5 + h * 0.2", "y": "y_right_notch1_top" } },
        { "from": { "x": "x5 + h * 0.2", "y": "y_right_notch1_top" }, "to": { "x": "x5", "y": "y_right_notch1_top" } },
        { "from": { "x": "x5", "y": "y_right_notch1_top" }, "to": { "x": "x5", "y": "y_right_notch2_bottom" } },
        { "from": { "x": "x5", "y": "y_right_notch2_bottom" }, "to": { "x": "x5 + h * 0.2", "y": "y_right_notch2_bottom" } },
        { "from": { "x": "x5 + h * 0.2", "y": "y_right_notch2_bottom" }, "to": { "x": "x5 + h * 0.2", "y": "y_right_notch2_top" } },
        { "from": { "x": "x5 + h * 0.2", "y": "y_right_notch2_top" }, "to": { "x": "x5", "y": "y_right_notch2_top" } },
        { "from": { "x": "x5", "y": "y_right_notch2_top" }, "to": { "x": "x5", "y": "y3" } },
        { "from": { "x": "x5", "y": "y3" }, "to": { "x": "x4", "y": "y3" } }
      ]
    },
    {
      "name": "side_dust_top_right",
      "accepts_content": false,
      "boundary": [
        { "from": { "x": "x4", "y": "y2" }, "to": { "x": "x3", "y": "y2" } },
        { "from": { "x": "x3", "y": "y2" }, "to": { "x": "x3", "y": "y1" } },
        { "from": { "x": "x3", "y": "y1" }, "to": { "x": "x4", "y": "y1" } },
        { "from": { "x": "x4", "y": "y1" }, "to": { "x": "x4", "y": "y2" } }
      ]
    },
    {
      "name": "side_dust_bottom_right",
      "accepts_content": false,
      "boundary": [
        { "from": { "x": "x3", "y": "y3" }, "to": { "x": "x4", "y": "y3" } },
        { "from": { "x": "x4", "y": "y3" }, "to": { "x": "x4", "y": "y4" } },
        { "from": { "x": "x4", "y": "y4" }, "to": { "x": "x3", "y": "y4" } },
        { "from": { "x": "x3", "y": "y4" }, "to": { "x": "x3", "y": "y3" } }
      ]
    }
  ],
  "folds": [
    {
      "from_panel": "bottom",
      "to_panel": "front_wall",
      "from_segment_index": 1,
      "to_segment_index": 3,
      "angle_rad": 0,
      "angle_expr": "wall_angle_rad",
      "direction": "toward_inside"
    },
    {
      "from_panel": "bottom",
      "to_panel": "back_wall",
      "from_segment_index": 3,
      "to_segment_index": 1,
      "angle_rad": 0,
      "angle_expr": "wall_angle_rad",
      "direction": "toward_inside"
    },
    {
      "from_panel": "back_wall",
      "to_panel": "top_lid",
      "from_segment_index": 3,
      "to_segment_index": 1,
      "angle_rad": 0,
      "angle_expr": "lid_angle_rad",
      "direction": "toward_inside"
    },
    {
      "from_panel": "top_lid",
      "to_panel": "top_lid_tuck",
      "from_segment_index": 3,
      "to_segment_index": 0,
      "angle_rad": 0,
      "angle_expr": "tuck_angle_rad",
      "direction": "toward_inside"
    },
    {
      "from_panel": "top_lid",
      "to_panel": "dust_flap_left",
      "from_segment_index": 0,
      "to_segment_index": 0,
      "angle_rad": 0,
      "angle_expr": "wall_angle_rad",
      "direction": "toward_inside"
    },
    {
      "from_panel": "top_lid",
      "to_panel": "dust_flap_right",
      "from_segment_index": 2,
      "to_segment_index": 0,
      "angle_rad": 0,
      "angle_expr": "wall_angle_rad",
      "direction": "toward_inside"
    },
    {
      "from_panel": "bottom",
      "to_panel": "side_outer_left",
      "from_segment_index": 0,
      "to_segment_index": 2,
      "angle_rad": 0,
      "angle_expr": "wall_angle_rad",
      "direction": "toward_inside"
    },
    {
      "from_panel": "side_outer_left",
      "to_panel": "side_inner_left",
      "from_segment_index": 0,
      "to_segment_index": 0,
      "angle_rad": 0,
      "angle_expr": "roll_fold_angle_rad",
      "direction": "toward_inside"
    },
    {
      "from_panel": "side_outer_left",
      "to_panel": "side_dust_top_left",
      "from_segment_index": 1,
      "to_segment_index": 0,
      "angle_rad": 0,
      "angle_expr": "wall_angle_rad",
      "direction": "toward_inside"
    },
    {
      "from_panel": "side_outer_left",
      "to_panel": "side_dust_bottom_left",
      "from_segment_index": 3,
      "to_segment_index": 0,
      "angle_rad": 0,
      "angle_expr": "wall_angle_rad",
      "direction": "toward_inside"
    },
    {
      "from_panel": "bottom",
      "to_panel": "side_outer_right",
      "from_segment_index": 2,
      "to_segment_index": 3,
      "angle_rad": 0,
      "angle_expr": "wall_angle_rad",
      "direction": "toward_inside"
    },
    {
      "from_panel": "side_outer_right",
      "to_panel": "side_inner_right",
      "from_segment_index": 1,
      "to_segment_index": 0,
      "angle_rad": 0,
      "angle_expr": "roll_fold_angle_rad",
      "direction": "toward_inside"
    },
    {
      "from_panel": "side_outer_right",
      "to_panel": "side_dust_top_right",
      "from_segment_index": 0,
      "to_segment_index": 0,
      "angle_rad": 0,
      "angle_expr": "wall_angle_rad",
      "direction": "toward_inside"
    },
    {
      "from_panel": "side_outer_right",
      "to_panel": "side_dust_bottom_right",
      "from_segment_index": 2,
      "to_segment_index": 0,
      "angle_rad": 0,
      "angle_expr": "wall_angle_rad",
      "direction": "toward_inside"
    }
  ],
  "linework": [
    {
      "role": "fold",
      "segments": [
        { "from": { "x": "x2", "y": "y2" }, "to": { "x": "x3", "y": "y2" } }
      ]
    },
    {
      "role": "fold",
      "segments": [
        { "from": { "x": "x2", "y": "y3" }, "to": { "x": "x3", "y": "y3" } }
      ]
    },
    {
      "role": "fold",
      "segments": [
        { "from": { "x": "x2", "y": "y4" }, "to": { "x": "x3", "y": "y4" } }
