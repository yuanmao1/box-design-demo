{
  "name": "box-design-demo",
  "version": "1.0.50",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build:wasm": "cd packages/geo-core && zig build -Doptimize=ReleaseSmall && cp zig-out/bin/geo-core.wasm ../../apps/frontend/public/geo-core.wasm",
    "test:geo-core": "cd packages/geo-core && zig build test",
    "gen:geo-template-spec": "zig run packages/geo-core/tools/template_json_to_spec.zig --",
    "dev:frontend": "bun run --filter './apps/frontend' dev",
    "dev:backend": "bun run --filter './apps/backend' dev",
    "build:frontend": "bun run --filter './apps/frontend' build",
    "check:frontend": "bun run --filter './apps/frontend' check",
    "test:frontend": "bun run --filter './apps/frontend' test"
  }
}
